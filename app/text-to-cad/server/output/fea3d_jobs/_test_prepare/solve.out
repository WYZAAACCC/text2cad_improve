          *****  ANSYS COMMAND LINE ARGUMENTS  *****
  INITIAL JOBNAME              = turbine3d                                                                                                                                                                                                                                               
  BATCH MODE REQUESTED (-b)    = LIST
  INPUT FILE COPY MODE (-c)    = COPY
  SHARED MEMORY PARALLEL REQUESTED
    SINGLE PROCESS WITH   4 THREADS REQUESTED
    TOTAL OF     4 CORES REQUESTED
  MEMORY REQUESTED (MB)        = 3000        

 RELEASE= Release 18.1         BUILD= 18.1      UP20170403   VERSION=WINDOWS x64 
 CURRENT JOBNAME=turbine3d  23:52:39  JUL 15, 2026 CP=      0.031

     1  /BATCH  
     2  /FILNAME,turbine3d  
     3  /TITLE,HP Turbine Disc 3D cyclic sector - centrifugal + radial thermal  
     4  /PREP7  
     5  ET,1,187                          ! SOLID187 二阶四面体
     6      
     7  ! ============ GH4169 温度相关材料 ([人工确认]表) ============   
     8  MPTEMP                            ! 清空温度表 
     9  MPTEMP,1,20,300,500,650 
    10  MPDATA,EX,1,1,205000,190000,178000,165000   
    11  MPDATA,ALPX,1,1,1.18e-05,1.35e-05,1.44e-05,1.54e-05 
    12  MP,PRXY,1,0.3   
    13  MP,DENS,1,8.24e-09                  ! tonne/mm3 !   
    14  TREF,20 
    15      
    16  /INPUT,mesh,inp                   ! 读入 gmsh 导出的节点/单元  
    17      
    18  ! ============ 参数 ============  
    19  PI=ACOS(-1) 
    20  OMG=15000*2*PI/60                 ! rad/s   
    21  RB=60 $ RO=249.97   
    22  TB=500 $ TR=650 $ TEXP=1
    23  THL=3 $ THH=9 $ SECT=6  
    24      
    25  ! ============ 节点旋入柱坐标系 (此后 UX=径向 UY=切向 UZ=轴向) ============ 
    26  CSYS,1  
    27  NROTAT,ALL  
    28      
    29  ! ============ 循环对称耦合: 仅选两切割面节点, CPCYC 自动配对 ============
    30  ! CSYS,1 下 NSEL LOC,Y 的单位是"度"   
    31  NSEL,S,LOC,Y,THL-0.01,THL+0.01  
    32  NSEL,A,LOC,Y,THH-0.01,THH+0.01  
    33  CPCYC,ALL,0.05,1,,SECT,,0         ! TOLER=0.05mm(网格严格周期匹配), KCN=1, DY=6$
    34  ALLSEL  
    35      
    36  ! ============ z=0 对称面 (镜像对称 → UZ=0, 同时消除轴向刚体平动) ============   
    37  NSEL,S,LOC,Z,-1E-3,1E-3 
    38  D,ALL,UZ,0  
    39  ALLSEL  
    40      
    41  ! ============ 消除绕轴刚体转动: 孔壁近 z=0 的 1 个节点 切向UY=0 ============  
    42  CSYS,1  
    43  NSEL,S,LOC,X,RB-0.5,RB+0.5  
    44  NSEL,R,LOC,Z,0,2.0  
    45  *GET,NANCH,NODE,0,NUM,MIN   
    46  ALLSEL  
    47  D,NANCH,UY,0
    48      
    49  ! ============ 径向分带温度场 T(r) = TB+(TR-TB)*((r-RB)/(RO-RB))**TEXP ============  
    50  NBAND=80
    51  *DO,I,1,NBAND   
    52    R1=RB+(I-1)*(RO-RB)/NBAND 
    53    R2=RB+I*(RO-RB)/NBAND 
    54    RM=(R1+R2)/2  
    55    TT=TB+(TR-TB)*((RM-RB)/(RO-RB))**TEXP 
    56    RS1=R1 $ RS2=R2   
    57    *IF,I,EQ,1,THEN   
    58      RS1=R1-2
    59    *ENDIF
    60    *IF,I,EQ,NBAND,THEN   
    61      RS2=R2+2
    62    *ENDIF
    63    NSEL,S,LOC,X,RS1,RS2  
    64    BF,ALL,TEMP,TT
    65  *ENDDO  
    66  ALLSEL  
    67      
    68  ! ============ 离心载荷 (绕全局Z轴, 与 CSYS 无关) ============   
    69  OMEGA,,,OMG 
    70  FINISH  
    71      
    72  /SOLU   
    73  ANTYPE,STATIC   
    74  EQSLV,SPARSE
    75  SOLVE   
    76  FINISH  
    77      
    78  ! ============ 后处理: 全三维节点应力场导出 ============   
    79  /POST1  
    80  SET,LAST
    81  RSYS,1                            ! 应力转柱坐标: SX=径向 SY=环向 SZ=轴向   
    82      
    83  *GET,NMAX,NODE,0,NUM,MAX
    84  *DIM,NID,ARRAY,NMAX 
    85  *VFILL,NID(1),RAMP,1,1  
    86  *DIM,MSK,ARRAY,NMAX 
    87  *DIM,XX,ARRAY,NMAX  
    88  *DIM,YY,ARRAY,NMAX  
    89  *DIM,ZZ,ARRAY,NMAX  
    90  *DIM,SR,ARRAY,NMAX  
    91  *DIM,SH,ARRAY,NMAX  
    92  *DIM,SA,ARRAY,NMAX  
    93  *DIM,SV,ARRAY,NMAX  
    94  *DIM,SP1,ARRAY,NMAX 
    95  *DIM,SP3,ARRAY,NMAX 
    96  *VGET,MSK(1),NODE,1,NSEL          ! 1=选中 0=不存在 -1=未选 (Python 侧过滤)   
    97  CSYS,0                            ! 坐标导出用笛卡尔
    98  *VGET,XX(1),NODE,1,LOC,X
    99  *VGET,YY(1),NODE,1,LOC,Y
   100  *VGET,ZZ(1),NODE,1,LOC,Z
   101  *VGET,SR(1),NODE,1,S,X            ! 径向 (RSYS,1) 
   102  *VGET,SH(1),NODE,1,S,Y            ! 环向  
   103  *VGET,SA(1),NODE,1,S,Z            ! 轴向  
   104  *VGET,SV(1),NODE,1,S,EQV          ! Von Mises   
   105  *VGET,SP1(1),NODE,1,S,1 
   106  *VGET,SP3(1),NODE,1,S,3 
   107  *CFOPEN,nodal_stress_3d,csv 
   108  *VWRITE 
   109  ('nid,x,y,z,s_radial,s_hoop,s_axial,s_eqv,s1,s3,sel')   
   110  *VWRITE,NID(1),XX(1),YY(1),ZZ(1),SR(1),SH(1),SA(1),SV(1),SP1(1),SP3(1),MSK(1)   
   111  (F9.0,',',F12.5,',',F12.5,',',F12.5,',',F11.3,',',F11.3,',',F11.3,',',F11.3,',',F11.3,',',F11.3,',',F4.0)   
   112  *CFCLOS 
   113      
   114  ! ============ 交叉核对指标 (权威指标由 Python 从 CSV 计算) ============  
   115  NSORT,S,EQV 
   116  *GET,VMMAX,SORT,,MAX
   117  NSEL,S,LOC,Z,-1E-3,1E-3 
   118  FSUM
   119  *GET,FZSUM,FSUM,0,ITEM,FZ         ! 对称面轴向反力合力应≈0  
   120  ALLSEL  
   121  *CFOPEN,result_summary,txt  
   122  *VWRITE,VMMAX   
   123  ('MAX_VON_MISES = ',F12.3,' MPa')   
   124  *VWRITE,FZSUM   
   125  ('SYM_PLANE_FZ_SUM = ',E14.5,' N')  
   126  *CFCLOS 
   127  FINISH  

