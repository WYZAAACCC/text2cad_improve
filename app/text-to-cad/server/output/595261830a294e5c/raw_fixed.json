  "llm_validation_hints": {
    "unsupported_capabilities": [
      "arbitrary R-Z ordered revolve polygon with thickness-by-radius — available via sketch_profile.revolve_profile v1.0.0 on XZ plane; fir_tree_slot with alternating neck/lobe stations, flank angles, and fillet radii — partially available via sketch_profile composed half-profile; final geometry_postcheck enforcing closed=true and is_valid_solid=true — enforced at constraint level via require_closed_solid"
    ],
    "self_checks": [
      "profile uses sketch_profile.revolve_profile on XZ (R-Z) plane, not axisymmetric.revolve_profile which only supports z-stacked monotonic r(z); fir-tree cutter profile uses half-profile with right-hand side >0 Y, left-hand side at Y=0 centerline; hub-web and web-rim transition radii use fillet_sketch@2.0.0 with semantic corner IDs; 60-slot pattern via composition.circular_pattern_component; M_B1-M_B4 are expressed as distinct geometric arc features in the cutter profile — neck entries are explicit step-downs (narrow→wide→narrow→wide→narrow). Slot mouth half-width ~4mm, first lobe max half-width ~8mm, second lobe max half-width ~7mm, root half-width ~3mm, slot depth ~24mm from OD to root floor."
    ]
  }
